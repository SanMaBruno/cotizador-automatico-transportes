# URL del webhook de Google Sheets Apps Script
# Instrucciones: ver docs/google-sheets-apps-script.js
COTIZADOR_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/TU_ID/exec

# SMTP para envio real de emails con Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USERNAME=tu_cuenta@gmail.com
SMTP_PASSWORD=tu_app_password_de_16_caracteres
SMTP_FROM=Transportes La Serena <tu_cuenta@gmail.com>

# false envia por SMTP. true simula envio sin mandar emails reales.
COTIZADOR_EMAIL_DRY_RUN=false
COTIZADOR_EMAIL_DRY_RUN_PATH=out/dry_run_emails.jsonl
COTIZADOR_EMAIL_OVERRIDE_TO=brunorodolfosanmartinnavarro@gmail.com

# URL del backend para el frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
